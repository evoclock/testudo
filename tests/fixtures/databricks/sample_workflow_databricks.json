{
  "name": "databricks-query-debrief-v015",
  "description": "Run a Databricks SQL query against the testudo sample tables, sanitise the rows (since they contain mock PII), and write a debrief. Requires the [databricks] extra and the env vars DATABRICKS_SERVER_HOSTNAME, DATABRICKS_HTTP_PATH, DATABRICKS_TOKEN to be exported.",
  "inputs": {
    "query": {
      "type": "string",
      "required": true,
      "description": "SQL query; the sample tables are testudo.employees and testudo.transactions."
    },
    "parameters": {
      "type": "array",
      "required": false,
      "default": []
    },
    "output_path": {
      "type": "file",
      "format": "markdown",
      "required": true
    }
  },
  "steps": [
    {
      "id": "query",
      "uses": "data.databricks_query",
      "with": {
        "query": "${inputs.query}",
        "parameters": "${inputs.parameters}"
      }
    },
    {
      "id": "write_results",
      "uses": "outputs.file",
      "needs": ["query"],
      "with": {
        "path": "${inputs.output_path}",
        "content": "${steps.query.rows}"
      }
    },
    {
      "id": "respond",
      "uses": "outputs.chat",
      "needs": ["write_results"],
      "with": {
        "text": "Databricks query returned rows; results saved.",
        "attachments": ["${steps.write_results.destination}"]
      }
    }
  ],
  "permissions": {
    "filesystem": { "read": ["/"], "write": ["/"] },
    "network": { "egress": ["*.cloud.databricks.com", "*.databricks.com"] },
    "process": { "spawn": false }
  },
  "isolation": {
    "primitive": "docker",
    "image": "testudo:0.1",
    "cpu": "2.0",
    "memory": "4g",
    "rollback": true
  }
}
