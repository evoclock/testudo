{
  "name": "drive-fetch-debrief-v015",
  "description": "Fetch a file from Google Drive by file_id, sanitise for PII and prompt-injection, write a redacted debrief. Requires the v0.2 connectors.google_drive implementation; until then the fetch step returns NotImplementedError.",
  "inputs": {
    "file_id": {
      "type": "string",
      "required": true,
      "description": "Google Drive file ID (33-char string from the share URL between /d/ and /)."
    },
    "output_path": {
      "type": "file",
      "format": "markdown",
      "required": true
    }
  },
  "steps": [
    {
      "id": "fetch",
      "uses": "connectors.google_drive",
      "with": { "file_id": "${inputs.file_id}" }
    },
    {
      "id": "sanitise",
      "uses": "sanitisers.pii_and_injection",
      "needs": ["fetch"],
      "with": {
        "content": "${steps.fetch.content}",
        "redact": true
      }
    },
    {
      "id": "write_debrief",
      "uses": "outputs.file",
      "needs": ["sanitise"],
      "with": {
        "path": "${inputs.output_path}",
        "content": "${steps.sanitise.content}"
      }
    },
    {
      "id": "respond",
      "uses": "outputs.chat",
      "needs": ["write_debrief"],
      "with": {
        "text": "Drive file fetched, sanitised, and written.",
        "attachments": ["${steps.write_debrief.destination}"]
      }
    }
  ],
  "permissions": {
    "filesystem": { "read": ["/"], "write": ["/"] },
    "network": { "egress": ["googleapis.com", "www.googleapis.com"] },
    "process": { "spawn": false }
  },
  "isolation": {
    "primitive": "docker",
    "image": "testudo:0.1",
    "cpu": "1.0",
    "memory": "2g",
    "rollback": true
  }
}
