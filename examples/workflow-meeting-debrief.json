{
  "name": "meeting-debrief-v01",
  "description": "Demo workflow for Testudo v0.1: ingest a meeting transcript, sanitise it, query the demo DuckDB for attendees, and write a debrief summary to disk plus a chat-inline response.",
  "inputs": {
    "transcript_path": {
      "type": "file",
      "format": "text",
      "required": true
    },
    "demo_db_path": {
      "type": "file",
      "format": "duckdb",
      "required": true
    },
    "meeting_id": {
      "type": "string",
      "required": false,
      "default": "M-001"
    },
    "output_path": {
      "type": "file",
      "format": "markdown",
      "required": true
    }
  },
  "steps": [
    {
      "id": "ingest",
      "uses": "connectors.local_file",
      "with": { "path": "${inputs.transcript_path}" }
    },
    {
      "id": "sanitise",
      "uses": "sanitisers.pii_and_injection",
      "needs": ["ingest"],
      "with": { "content": "${steps.ingest.content}", "redact": true }
    },
    {
      "id": "lookup_attendees",
      "uses": "data.duckdb_query",
      "with": {
        "database": "${inputs.demo_db_path}",
        "query": "SELECT name, role FROM attendees WHERE meeting_id = ?",
        "parameters": ["${inputs.meeting_id}"]
      }
    },
    {
      "id": "write_debrief",
      "uses": "outputs.file",
      "needs": ["sanitise", "lookup_attendees"],
      "with": {
        "path": "${inputs.output_path}",
        "content": "${steps.sanitise.content}"
      }
    },
    {
      "id": "respond",
      "uses": "outputs.chat",
      "needs": ["write_debrief"],
      "with": {
        "text": "Debrief written; transcript sanitised; attendees retrieved.",
        "attachments": ["${steps.write_debrief.destination}"]
      }
    }
  ],
  "permissions": {
    "filesystem": {
      "read": ["/inputs"],
      "write": ["/runs"]
    },
    "network": {
      "egress": []
    },
    "process": {
      "spawn": false
    }
  },
  "isolation": {
    "primitive": "docker",
    "image": "testudo:0.1",
    "cpu": "1.0",
    "memory": "2g",
    "rollback": true
  }
}
