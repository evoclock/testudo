# .env.testudo.example -- bridge + renderer auth template
#
# Usage:
#   cp .env.testudo.example .env.testudo
#   chmod 600 .env.testudo
#   # generate a real token in place of the placeholder:
#   sed -i "s|REPLACE-WITH-OPENSSL-RAND-HEX-32|$(openssl rand -hex 32)|" .env.testudo
#   # then in each shell that needs it:
#   source .env.testudo
#
# Real .env.testudo is gitignored. This file (the .example) is committed.
#
# When NOT to use this file:
#   If you are happy copy-pasting the bearer token from `testudo serve`
#   stderr into the Electron shell once per session, skip the file
#   entirely. The vars below are a convenience for pinning a token
#   across both processes so the paste step goes away.

# -----------------------------------------------------------------------------
# Required (active today)
# -----------------------------------------------------------------------------

# Bearer token shared between the FastAPI bridge and the Electron
# renderer. Pin it to a random 32-byte hex string so both processes
# pick up the same value via `source .env.testudo`. If unset,
# `testudo serve` generates a fresh token at startup and prints it to
# stderr for you to copy.
export TESTUDO_BRIDGE_TOKEN="REPLACE-WITH-OPENSSL-RAND-HEX-32"

# -----------------------------------------------------------------------------
# Optional (active today, defaults usually fine)
# -----------------------------------------------------------------------------

# Bridge URL the renderer talks to. Default 127.0.0.1:8000 matches
# `testudo serve --port 8000`. Set explicitly if you run the bridge on
# a different host or port.
# export TESTUDO_BRIDGE_URL="http://127.0.0.1:8000"

# -----------------------------------------------------------------------------
# Future use (inactive in v0.1.5; required only when v0.1.6 wires the
# MCP server triad into the default orchestrator path)
# -----------------------------------------------------------------------------

# HMAC key the read-only llm_response_capturer signs sanitisation
# receipts with; checked by the write-only file_writer before any
# disk write. Only matters when the MCP servers run as subprocesses,
# which v0.1.5 does not do by default.
# export TESTUDO_RECEIPT_KEY="REPLACE-WITH-OPENSSL-RAND-HEX-32"

# Directory the file_writer MCP server is allowed to write under.
# Same caveat as TESTUDO_RECEIPT_KEY: only used when the MCP servers
# run as subprocesses.
# export TESTUDO_REPO_ROOT="/home/jgamboa/testudo"
