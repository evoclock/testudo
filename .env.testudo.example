# .env.testudo.example -- template for testudo bridge + receipt key
#
# Usage:
#   cp .env.testudo.example .env.testudo
#   chmod 600 .env.testudo
#   # fill in real values, then:
#   source .env.testudo
#
# Real .env.testudo is gitignored. This file (the .example) is committed.

# Bridge bearer token. testudo serve generates one at startup if not set
# and prints it to stderr; pin it here if you prefer a stable token across
# restarts. Use a high-entropy value (32+ bytes urlsafe).
export TESTUDO_BRIDGE_TOKEN="REPLACE-WITH-OPENSSL-RAND-HEX-32"

# Bridge URL (renderer side). Defaults to http://127.0.0.1:8000 which
# matches `testudo serve --port 8000`. Change only if you run the bridge
# on a different port or host.
export TESTUDO_BRIDGE_URL="http://127.0.0.1:8000"

# Per-run HMAC key used by the read-only LLM capturer to sign sanitisation
# receipts the write-only file_writer validates. Required when running the
# MCP servers as STDIO subprocesses. 32+ bytes random.
export TESTUDO_RECEIPT_KEY="REPLACE-WITH-OPENSSL-RAND-HEX-32"

# Repo root the file_writer MCP server is allowed to write under. Defaults
# to the cwd of the subprocess. Set explicitly to an absolute path so
# every write resolves under a known boundary.
export TESTUDO_REPO_ROOT="/home/jgamboa/testudo"
