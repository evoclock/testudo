# .env.databricks.example -- template for the Databricks SQL adapter
#
# Usage:
#   cp .env.databricks.example .env.databricks
#   chmod 600 .env.databricks
#   # fill in real values, then:
#   source .env.databricks
#
# Real .env.databricks is gitignored. This file (the .example) is committed.

# SQL Warehouse hostname. Workspace UI -> SQL Warehouses -> your warehouse
# -> "Connection details" tab -> "Server hostname".
export DATABRICKS_SERVER_HOSTNAME="dbc-abc1234d-5678.cloud.databricks.com"

# HTTP path for the same warehouse. Same Connection details tab.
export DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/abc123def456"

# Personal access token. User settings -> Developer -> Access tokens
# -> Generate new token. Rotate every 90 days.
#
# Scope: pick `sql` if your workspace exposes fine-grained PATs;
# otherwise a legacy no-scope PAT works (bound to your user's
# permissions; ensure you have CAN USE on the warehouse and SELECT on
# the tables you query).
export DATABRICKS_TOKEN="dapi-REPLACE-WITH-YOUR-TOKEN"

# Optional: catalog and schema defaults when the workflow doesn't
# qualify the table name. Leave commented if every query uses
# fully-qualified names (e.g. samples.nyctaxi.trips).
# export DATABRICKS_CATALOG="main"
# export DATABRICKS_SCHEMA="default"
