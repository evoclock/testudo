# .env.ollama.example -- template for the local Ollama model adapter
#
# Usage:
#   cp .env.ollama.example .env.ollama
#   chmod 600 .env.ollama
#   # adjust values if your Ollama runs elsewhere, then:
#   source .env.ollama
#
# Real .env.ollama is gitignored. This file (the .example) is committed.
#
# See docs/OLLAMA_SETUP.md for ollama install, model pull, and the
# `ollama serve` daemon.

# Base URL for the Ollama HTTP API. Defaults to the local daemon on
# port 11434. Change only if Ollama runs on a different host or port
# (e.g. a remote GPU box).
export TESTUDO_OLLAMA_URL="http://localhost:11434"

# Optional: default model name when a workflow does not pin one. The
# bundled workflow-pdf-summarise.json reads its model from the inputs
# dict and falls back to the workflow's own default ("minimax-m2.5");
# this env var is for one-off CLI calls.
# export TESTUDO_OLLAMA_MODEL="minimax-m2.5"
