# .env.drive.example -- template for the Google Drive connector (v0.2)
#
# Usage:
#   cp .env.drive.example .env.drive
#   chmod 600 .env.drive
#   # fill in the real path to your service-account JSON key, then:
#   source .env.drive
#
# Real .env.drive is gitignored. This file (the .example) is committed.
#
# See docs/GOOGLE_DRIVE_SETUP.md for the full Cloud Console walkthrough
# (project, enable Drive API, service account, JSON key, folder share).

# Absolute path to the service-account JSON key downloaded from
# Google Cloud Console. Store the key outside this repo so an
# accidental `git add` cannot reach it. Suggested location:
#   ~/.config/testudo/drive-service-account.json
export TESTUDO_DRIVE_CREDENTIALS="${HOME}/.config/testudo/drive-service-account.json"

# OAuth scope. drive.readonly is enough for ingest workflows. Use the
# full `drive` scope only if a workflow needs to write back into the
# folder (rare).
export TESTUDO_DRIVE_SCOPES="https://www.googleapis.com/auth/drive.readonly"

# Optional: pin the Drive folder ID the service account is allowed to
# enumerate. If unset, the connector lists every file the service
# account has been shared with. Folder ID is the 33-character string
# in the folder URL after /folders/.
# export TESTUDO_DRIVE_FOLDER_ID="REPLACE-WITH-FOLDER-ID"
